post_patch() {
	vsed -i "s/meson.add_install_script/# meson.add_install_script/" meson.build
	vsed -i '1s|^|#include <sys/types.h>\n|' include/DesktopEnvironment/DesktopEnvironmentKde.hpp
	vsed -i '/^#include <fcntl.h>/i #include <unistd.h>' src/DesktopEnvironment/DesktopEnvironmentKde.cpp
	vsed -i '/^#include <fcntl.h>/i #include <unistd.h>' src/DesktopEnvironment/DesktopEnvironmentGnome.cpp
}

